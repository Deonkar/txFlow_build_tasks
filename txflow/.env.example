# Kafka / Redpanda
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092
PAYMENTS_TOPIC=payments.initiated
DLQ_TOPIC=payments.dlq
LOG_RETENTION_MS=604800000   # 7 days

# PostgreSQL
DATABASE_URL=postgresql://txflow:txflow@postgres:5432/txflow

# Redis
REDIS_URL=redis://redis:6379

# App
PORT=8000
DEDUP_TTL_SECONDS=86400      # 24 hours
MAX_RETRY_ATTEMPTS=3
RETRY_BASE_DELAY_MS=500
FRAUD_THRESHOLD=10000

